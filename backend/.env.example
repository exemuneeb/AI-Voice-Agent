# Copy this file to `.env` and fill in your keys.
# Never commit your real .env file.

# ---- LLM (agent brain) ----
LLM_PROVIDER=groq            # "groq" or "openai"
LLM_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=

# ---- Speech-to-Text (Whisper) ----
STT_PROVIDER=groq            # "groq" (whisper-large-v3) or "openai" (whisper-1)

# ---- Text-to-Speech ----
TTS_PROVIDER=edge            # "edge" (free, no key needed) or "elevenlabs" (paid plan required for API)
EDGE_VOICE=en-US-AriaNeural   # see README for how to list other free Edge voices

# Only needed if TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# ---- App ----
AGENT_NAME=Aria
FRONTEND_ORIGIN=*            # comma-separated allowed origins in production, e.g. https://your-app.vercel.app
MAX_AUDIO_MB=15
MAX_HISTORY_TURNS=12
PORT=8000
